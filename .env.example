# Copy to .env.local and fill in secrets (never commit .env.local).
ODDS_API_KEY=

# Cron automation (Cloudflare Worker + /api/cron/* routes)
CRON_SECRET=
SCRAPER_ALERT_WEBHOOK_URL=
SITE_URL=https://refwatch.ca

# Enterprise API keys are stored in data/api-keys.db (local) or Cloudflare D1 (API_KEYS_DB).
# Seed demo keys with: npx tsx scripts/seed-api-keys.ts
# Seed webhook subscribers with: REFWATCH_WEBHOOK_URL=https://example.com/hooks/refwatch npx tsx scripts/seed-webhook-subscribers.ts
