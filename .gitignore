# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/artifacts/

# next.js
/.next/
/out/
.open-next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
.dev.vars
.wrangler/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated at runtime by npm run morning-slate
/data/alerts.json

# copied from data/ during npm run build for Cloudflare static asset serving
/public/data/

# local dev caches (background ingest / stats queries — never commit)
/data/stats-query-log.jsonl
/data/insights-cache/

# BBR ingest HTML cache (fetched locally; not shipped)
/data/nba/cache/

# enterprise API key storage (local sqlite/json fallback — never commit)
/data/api-keys.db
/data/api-keys.json
/data/webhook-queue.json
/data/anomaly-events.json

# nflverse raw PBP CSV cache and penalty index (rebuild via npm run rebuild-nfl-gsni)
/data/nfl/pbp-cache/
/data/nfl/penalty-events-by-game.json
