{
  "name": "ref-watch-nba",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "tsx scripts/copy-data-to-public.ts && node scripts/next-build-retry.mjs",
    "preview": "tsx scripts/copy-data-to-public.ts && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "tsx scripts/copy-data-to-public.ts && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "tsx scripts/copy-data-to-public.ts && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/nfl/data-source.test.ts src/lib/nba-team-season-records.test.ts src/lib/bbr-ref-team-records.test.ts",
    "fetch-assignments": "tsx scripts/fetch-assignments.ts",
    "fetch-odds": "tsx scripts/fetch-odds.ts",
    "morning-slate": "tsx scripts/morning-slate.ts",
    "build-ref-data": "tsx scripts/build-ref-data.ts",
    "build-bbr-ref-team-data": "tsx scripts/build-bbr-ref-team-data.ts",
    "generate-ref-seed": "tsx scripts/generate-comprehensive-seed.ts",
    "fetch-nhl-ref-photos": "tsx scripts/nhl/fetch-ref-photos.ts",
    "fetch-nhl-assignments": "tsx scripts/nhl/fetch-assignments.ts",
    "fetch-nhl-odds": "tsx scripts/nhl/fetch-odds.ts",
    "fetch-nhl-team-special-teams": "tsx scripts/nhl/fetch-team-special-teams.ts",
    "generate-nhl-seed": "tsx scripts/nhl/generate-seed.ts",
    "build-nhl-data": "tsx scripts/nhl/build-ref-data.ts",
    "generate-nfl-seed": "tsx scripts/nfl/generate-seed.ts",
    "build-nfl-data": "tsx scripts/nfl/build-ref-data.ts",
    "generate-cbb-seed": "tsx scripts/cbb/generate-seed.ts",
    "build-cbb-data": "tsx scripts/cbb/build-ref-data.ts",
    "generate-cfb-seed": "tsx scripts/cfb/generate-seed.ts",
    "build-cfb-data": "tsx scripts/cfb/build-ref-data.ts",
    "generate-epl-seed": "tsx scripts/epl/generate-seed.ts",
    "build-epl-data": "tsx scripts/epl/build-ref-data.ts",
    "fetch-epl-ref-photos": "tsx scripts/epl/fetch-ref-photos.ts",
    "fetch-nfl-assignments": "tsx scripts/nfl/fetch-assignments.ts",
    "fetch-nfl-ref-photos": "tsx scripts/nfl/fetch-ref-photos.ts",
    "fetch-nfl-odds": "tsx scripts/nfl/fetch-odds.ts",
    "compute-baselines": "tsx scripts/compute-baselines.ts",
    "backtest": "tsx scripts/backtest.ts",
    "honesty-audit": "tsx scripts/honesty-audit.ts",
    "validate-nfl": "node scripts/validate-nfl-accuracy.js",
    "validate": "npm run typecheck && npm run honesty-audit && npm run validate-nfl"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  }
}
