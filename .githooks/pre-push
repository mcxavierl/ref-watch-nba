#!/usr/bin/env bash
set -euo pipefail

echo "pre-push: mandatory preflight checks..."
npm run check:preflight

echo "pre-push: fast CSS syntax check..."
npm run check:css-syntax

if [[ "${SKIP_SHIP_CHECK:-}" == "1" ]]; then
  echo "pre-push: SKIP_SHIP_CHECK=1 — skipping full check:ci (theme matrix / Playwright)"
  echo "pre-push: GitHub CI validate must pass before merge"
  exit 0
fi

echo "pre-push: running full ship guardrails (npm run check:ci)..."
npm run check:ci
