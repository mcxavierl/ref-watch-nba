#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_SHIP_CHECK:-}" == "1" ]]; then
  echo "pre-push: SKIP_SHIP_CHECK=1 — skipping ship guardrails"
  exit 0
fi

echo "pre-push: running ship guardrails (npm run check:ci)..."
echo "pre-push: set SKIP_SHIP_CHECK=1 to bypass in an emergency"
npm run check:ci
